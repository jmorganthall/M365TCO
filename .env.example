# Copy to .env and fill in. Never commit a real .env.
# Two kinds of variable live here, both OPERATIONAL config only — never domain
# data (see docs/DATA_ARCHITECTURE.md). The OpenRouter API key is NOT here; it's
# set in-app and stored encrypted. Price-sheet sync credentials use the env vars
# below (cert path / client secret injected at runtime) and store no token.

# --- Compose-level (host) settings, consumed by docker-compose.yml ---
# Host port mapped to the container's 8000.
M365TCO_WEB_PORT=8080
# Host appdata directory mounted at /data (Unraid default shown).
M365TCO_DATA_DIR=/mnt/cache/appdata/m365tco

# --- App settings, read by the container (TCO_ prefix) ---
# Unlocks the encrypted local secret store. REQUIRED. Use a long random value.
TCO_MASTER_SECRET=change-me-to-a-long-random-string

# Comma-separated CORS origins (use specific origins in production).
TCO_CORS_ORIGINS=*

# --- One-click update (optional Watchtower sidecar; see docker-compose.yml) ---
# Token protecting Watchtower's HTTP update API. Set a long random value here (it
# configures the watchtower container) AND paste the SAME value into the app under
# Settings › Secrets › "Watchtower update API token" so the "Update now" button can
# authenticate. Leave blank to disable one-click updates.
WATCHTOWER_HTTP_API_TOKEN=
# How often Watchtower also auto-checks for a new image (seconds; default 24h).
# Set to 0 for on-demand-only (update solely via the in-app button).
WATCHTOWER_POLL_INTERVAL=86400
# Where the app reaches Watchtower's HTTP API (internal compose network default;
# override only if you run Watchtower on a different host/port).
TCO_WATCHTOWER_URL=http://watchtower:8080

# Fallback OpenRouter model. The operator picks the actual model in Settings
# (searchable list pulled live from OpenRouter); this env value is only used
# until one is chosen. The API key is also set in-app, not here.
TCO_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Price-sheet sync (Partner Center) is configured entirely in the app UI
# (Settings > Pricing sync), NOT via environment variables. Credentials are
# stored encrypted (unlocked by TCO_MASTER_SECRET). Nothing to set here.

# Persistence is fixed to the /data volume by docker-compose.yml:
#   TCO_DATABASE_URL=sqlite:////data/tco.db
#   TCO_DATA_DIR=/data
# For a non-container / Azure deployment, point at managed Postgres instead:
#   TCO_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/tco
