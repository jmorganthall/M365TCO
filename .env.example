# Copy to .env and fill in. Never commit a real .env.
# These are the ONLY operational settings; secrets (OpenRouter key, Partner
# Center refresh token) are set in-app and stored encrypted, not here.

# Unlocks the encrypted local secret store. Pick a long random value.
TCO_MASTER_SECRET=change-me-to-a-long-random-string

# Persistence. Default is SQLite on the /data volume. For Azure / Postgres:
# TCO_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/tco
TCO_DATABASE_URL=sqlite:////data/tco.db
TCO_DATA_DIR=/data

# Comma-separated CORS origins (use specific origins in production).
TCO_CORS_ORIGINS=*

# OpenRouter model for AI coverage suggestions (key is set in-app).
TCO_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
