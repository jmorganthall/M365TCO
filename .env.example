# Copy to .env and fill in. Never commit a real .env.
# Two kinds of variable live here, both OPERATIONAL config only — never domain
# data (see docs/DATA_ARCHITECTURE.md). Secrets like the OpenRouter key and
# Partner Center tokens are NOT here; they're set in-app and stored encrypted.

# --- Compose-level (host) settings, consumed by docker-compose.yml ---
# Host port mapped to the container's 8000.
M365TCO_WEB_PORT=8080
# Host appdata directory mounted at /data (Unraid default shown).
M365TCO_DATA_DIR=/mnt/cache/appdata/m365tco

# --- App settings, read by the container (TCO_ prefix) ---
# Unlocks the encrypted local secret store. REQUIRED. Use a long random value.
TCO_MASTER_SECRET=change-me-to-a-long-random-string

# Comma-separated CORS origins (use specific origins in production).
TCO_CORS_ORIGINS=*

# Fallback OpenRouter model. The operator picks the actual model in Settings
# (searchable list pulled live from OpenRouter); this env value is only used
# until one is chosen. The API key is also set in-app, not here.
TCO_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Persistence is fixed to the /data volume by docker-compose.yml:
#   TCO_DATABASE_URL=sqlite:////data/tco.db
#   TCO_DATA_DIR=/data
# For a non-container / Azure deployment, point at managed Postgres instead:
#   TCO_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/tco
